# Copy this file to ".env" for local dev and fill in the values.
# In production (Vercel), set these in Project Settings -> Environment Variables instead.
#
# NOTE: anything prefixed with VITE_ is embedded in the client bundle and is
# therefore PUBLIC. The Client ID is meant to be public. Access control for
# /live is the Spotify development-mode allowlist — only whitelisted accounts
# can complete OAuth (see README "Security model").

# Spotify app Client ID (from https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=b63e303503124ffe97135b9f00f3a53c

# Must EXACTLY match a Redirect URI registered on the Spotify app.
# Local dev:
VITE_SPOTIFY_REDIRECT_URI=https://localhost:5173/callback
# Production (set this value in Vercel, not here):
# VITE_SPOTIFY_REDIRECT_URI=https://music.jaxontravis.com/callback
